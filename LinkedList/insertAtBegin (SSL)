void insertAtBegin(char *s){
	struct node* newNode = (struct node*)malloc(sizeof(struct node));
	newNode->data = s;
	newNode->next = NULL;
	if(head==NULL){
		head = newNode;
		return;
	}
	newNode->next = head;
	head = newNode;
}
void display(){
	struct node* temp = head;
	while(temp!=NULL){
		printf("%s ", temp->data);
		temp = temp->next;
	}
}
int main(){
	int n;
	scanf("%d", &n);
	for(int i=0;i<n;i++){
		char *s = (char*)malloc(sizeof(101));
		scanf("%s", s);
		insertAtBegin(s);
	}
	display();
}
